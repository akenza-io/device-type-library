{
  "$id": "https://akenza.io/wika/netris2/default.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "processingType": "uplink_decoder",
  "topic": "default",
  "title": "Default",
  "properties": {
    "channel1": {
      "title": "Channel 1 Pressure",
      "description": "Channel 1 Pressure in bar",
      "$ref": "https://raw.githubusercontent.com/akenza-io/device-type-library/main/data-models/environment/schema.json#/$defs/pressure/bar"
    },
    "channel2": {
      "title": "Channel 2 Pressure",
      "description": "Channel 2 Pressure in bar",
      "$ref": "https://raw.githubusercontent.com/akenza-io/device-type-library/main/data-models/environment/schema.json#/$defs/pressure/bar"
    },
    "delta": {
      "title": "Delta",
      "description": "Delta from channel 1 and channel 2",
      "$ref": "https://raw.githubusercontent.com/akenza-io/device-type-library/main/data-models/environment/schema.json#/$defs/pressure/bar"
    },
    "deltaReverse": {
      "title": "Delta reverse",
      "description": "Delta from channel 2 and channel 1",
      "$ref": "https://raw.githubusercontent.com/akenza-io/device-type-library/main/data-models/environment/schema.json#/$defs/pressure/bar"
    },
    "ongoingAlarm": {
      "title": "Ongoing alarm",
      "type": "boolean",
      "description": "Equals true if theres an ongoing alarm",
      "hideFromKpis": true
    }
  }
}