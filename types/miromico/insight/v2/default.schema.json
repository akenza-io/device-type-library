      "description": "Indoor Air Quality Index (VOC)"
    },
    "iaqAccuracy": {
      "title": "IAQ Accuracy",
      "type": "integer",
      "description": "Accuracy of the IAQ measurement"
    }
  },
  "required": [],
  "$id": "https://akenza.io/miromico/insight/default.schema.json"
