{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "processingType": "uplink_decoder",
  "topic": "configuration",
  "title": "Configuration",
  "properties": {
    "measurementInterval": {
      "title": "Measurement Interval",
      "type": "integer",
      "unit": "s",
      "description": "Interval between measurements in seconds",
      "hideFromKpis": true
    },
    "sendCycle": {
      "title": "Send Cycle",
      "type": "integer",
      "description": "Number of measurements to accumulate before sending",
      "hideFromKpis": true
    },
    "confirmedUplinks": {
      "title": "Confirmed Uplinks",
      "type": "boolean",
      "description": "Flag indicating if confirmed uplinks are enabled",
      "hideFromKpis": true
    },
    "ledOn": {
      "title": "LED On",
      "type": "boolean",
      "description": "Flag indicating if LED is enabled",
      "hideFromKpis": true
    },
    "adrOn": {
      "title": "ADR On",
      "type": "boolean",
      "description": "Flag indicating if Adaptive Data Rate is enabled",
      "hideFromKpis": true
    },
    "contVocMeas": {
      "title": "Continuous VOC Measurement",
      "type": "boolean",
      "description": "Flag for continuous VOC measurement",
      "hideFromKpis": true
    },
    "reportInterval": {
      "title": "Report Interval",
      "type": "boolean",
      "description": "Flag to include measurement interval in reports",
      "hideFromKpis": true
    },
    "retransmissions": {
      "title": "Retransmissions",
      "type": "integer",
      "description": "Number of retransmissions configured",
      "hideFromKpis": true
    },
    "co2Subsamples": {
      "title": "CO2 Subsamples",
      "type": "integer",
      "description": "Number of CO2 subsamples",
      "hideFromKpis": true
    },
    "abcPeriod": {
      "title": "ABC Period",
      "type": "integer",
      "unit": "h",
      "description": "Automatic Baseline Correction period in hours",
      "hideFromKpis": true
    },
    "doorStatusTime": {
      "title": "Door Status Time",
      "type": "integer",
      "unit": "s",
      "description": "Interval for door status reports",
      "hideFromKpis": true
    },
    "hallDebounce": {
      "title": "Hall Debounce",
      "type": "integer",
      "unit": "ms",
      "description": "Debounce time for the Hall sensor",
      "hideFromKpis": true
    },
    "blindAdrProfile": {
      "title": "Blind ADR Profile",
      "type": "integer",
      "description": "Configured Blind ADR profile ID",
      "hideFromKpis": true
    },
    "co2Threshold": {
      "title": "CO2 Threshold",
      "type": "integer",
      "unit": "ppm",
      "description": "Conditional TX CO2 threshold",
      "hideFromKpis": true
    },
    "tempThreshold": {
      "title": "Temperature Threshold",
      "type": "number",
      "unit": "°C",
      "description": "Conditional TX temperature threshold",
      "hideFromKpis": true
    },
    "humThreshold": {
      "title": "Humidity Threshold",
      "type": "integer",
      "unit": "%",
      "description": "Conditional TX humidity threshold",
      "hideFromKpis": true
    },
    "lightInterval": {
      "title": "Light Interval",
      "type": "integer",
      "description": "Multiplier of send cycles for light measurement",
      "hideFromKpis": true
    }
  },
  "required": [],
  "$id": "https://akenza.io/miromico/insight/configuration.schema.json"
}