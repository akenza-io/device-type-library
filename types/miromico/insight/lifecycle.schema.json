{
  "$id": "https://akenza.io/miromico/insight-enhanced/lifecycle.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "processingType": "uplink_decoder",
  "topic": "lifecycle",
  "title": "Lifecycle",
  "properties": {
    "batteryVoltage": {
      "$ref": "https://raw.githubusercontent.com/akenza-io/device-type-library/main/data-models/device/schema.json#/$defs/batteryVoltage/volt"
    },
    "batteryLevel": {
      "$ref": "https://raw.githubusercontent.com/akenza-io/device-type-library/main/data-models/device/schema.json#/$defs/batteryLevel/percent"
    },
    "firmwareHash": {
      "title": "Firmware Hash",
      "type": "string",
      "description": "Git hash of the running firmware."
    },
    "noiseAlarm": {
      "title": "Noise Alarm",
      "type": "boolean",
      "description": "Whether a noise alarm was triggered."
    },
    "noiseLevel": {
      "title": "Noise Level",
      "type": "integer",
      "minimum": 0,
      "maximum": 255,
      "description": "Noise level that triggered the alarm."
    }
  }
}
