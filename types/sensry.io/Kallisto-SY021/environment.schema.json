{
  "$id": "https://akenza.io/sensry.io/Kallisto-SY021/environment.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "topic": "environment",
  "title": "Environment",
  "description": "",
