{
  "$id": "https://akenza.io/inbiot/mica/default.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "processingType": "uplink_decoder",
  "topic": "default",
  "title": "Default",
  "properties": {
    "temperature": {
      "$ref": "https://raw.githubusercontent.com/akenza-io/device-type-library/main/data-models/environment/schema.json#/$defs/temperature/celsius"
    },
    "humidity": {
      "$ref": "https://raw.githubusercontent.com/akenza-io/device-type-library/main/data-models/environment/schema.json#/$defs/humidity/percent"
    },
    "co2": {
      "type": "number",
      "title": "CO2",
      "description": "CO2 concentration in ppm"
    },
    "tvoc": {
      "type": "number",
      "title": "TVOC",
      "description": "Total Volatile Organic Compounds in ppb"
    },
    "pm2_5": {
      "type": "number",
      "title": "PM2.5",
      "description": "Particulate Matter 2.5 in ug/m3"
    },
    "pm10": {
      "type": "number",
      "title": "PM10",
      "description": "Particulate Matter 10 in ug/m3"
    },
    "vIndex": {
      "type": "number",
      "title": "Ventilation Index",
      "description": "Calculated ventilation index"
    },
    "tIndex": {
      "type": "number",
      "title": "Thermal Index",
      "description": "Calculated thermal comfort index"
    },
    "virusIndex": {
      "type": "number",
      "title": "Virus Index",
      "description": "Calculated virus survival index"
    },
    "iaqIndex": {
      "type": "number",
      "title": "IAQ Index",
      "description": "Overall Indoor Air Quality Index"
    },
    "moldIndex": {
      "type": "number",
      "title": "Mold Index",
      "description": "Calculated mold growth risk index"
    },
    "moldIndexStatus": {
      "type": "string",
      "title": "Mold Index Status",
      "description": "Status text for mold index (e.g. Calculating)"
    },
    "dB": {
      "type": "number",
      "title": "Noise Level dB",
      "description": "Ambient noise level in decibels"
    },
    "dBStatus": {
      "type": "string",
      "title": "Noise Level dB Status",
      "description": "Status text for noise level (e.g. Preheating)"
    },
    "counter": {
      "type": "number",
      "title": "Message Counter",
      "description": "Incrementing message counter value"
    },
    "type": {
      "type": "string",
      "title": "Device Type",
      "description": "Device model identifier"
    }
  },
  "required": [
    "temperature",
    "humidity",
    "co2",
    "tvoc",
    "pm2_5",
    "pm10"
  ]
}
