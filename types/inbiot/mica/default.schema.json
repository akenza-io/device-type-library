{
  "$id": "https://akenza.io/inbiot/mica/default.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "processingType": "uplink_decoder",
  "topic": "default",
  "title": "Default",
  "properties": {
    "temperature": {
      "$ref": "https://raw.githubusercontent.com/akenza-io/device-type-library/main/data-models/environment/schema.json#/$defs/temperature/celsius"
    },
    "humidity": {
      "$ref": "https://raw.githubusercontent.com/akenza-io/device-type-library/main/data-models/environment/schema.json#/$defs/humidity/percent"
    },
    "co2": {
      "type": "number",
      "title": "CO2",
      "description": "CO2 concentration in ppm"
    },
    "tvoc": {
      "type": "number",
      "title": "TVOC",
      "description": "Total Volatile Organic Compounds in ppb"
    },
    "pm2_5": {
      "type": "number",
      "title": "PM2.5",
      "description": "Particulate Matter 2.5 in ug/m3"
    },
    "pm10": {
      "type": "number",
      "title": "PM10",
      "description": "Particulate Matter 10 in ug/m3"
    },
    "vIndex": {
      "type": "number",
      "title": "Ventilation Index"
    },
    "tIndex": {
      "type": "number",
      "title": "Thermal Index"
    },
    "virusIndex": {
      "type": "number",
      "title": "Virus Index"
    },
    "iaqIndex": {
      "type": "number",
      "title": "IAQ Index"
    },
    "moldIndex": {
      "type": ["number", "string"],
      "title": "Mold Index"
    },
    "dB": {
      "type": ["number", "string"],
      "title": "Noise Level dB"
    },
    "counter": {
      "type": "number",
      "title": "Message Counter"
    },
    "type": {
      "type": "string",
      "title": "Device Type"
    }
  },
  "required": [
    "temperature",
    "humidity",
    "co2",
    "tvoc",
    "pm2_5",
    "pm10"
  ]
}
