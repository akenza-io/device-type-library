{
  "$id": "https://akenza.io/inbiot/well/default.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "processingType": "uplink_decoder",
  "topic": "default",
  "title": "Default",
  "properties": {
    "temperature": {
      "$ref": "https://raw.githubusercontent.com/akenza-io/device-type-library/main/data-models/environment/schema.json#/$defs/temperature/celsius"
    },
    "humidity": {
      "$ref": "https://raw.githubusercontent.com/akenza-io/device-type-library/main/data-models/environment/schema.json#/$defs/humidity/percent"
    },
    "co2": {
      "type": "number",
      "title": "CO2",
      "description": "CO2 concentration in ppm"
    },
    "tvoc": {
      "type": "number",
      "title": "TVOC",
      "description": "Total Volatile Organic Compounds"
    },
    "pm2_5": {
      "type": "number",
      "title": "PM2.5",
      "description": "Particulate Matter 2.5"
    },
    "pm10": {
      "type": "number",
      "title": "PM10",
      "description": "Particulate Matter 10"
    },
    "ch2o": {
      "type": ["number", "string"],
      "title": "Formaldehyde CH2O"
    },
    "pm1_0": {
      "type": "number",
      "title": "PM1.0"
    },
    "pm4": {
      "type": "number",
      "title": "PM4"
    },
    "o3": {
      "type": ["number", "string"],
      "title": "Ozone O3",
      "description": "Ozone concentration in ppb"
    },
    "no2": {
      "type": ["number", "string"],
      "title": "Nitrogen Dioxide NO2",
      "description": "NO2 concentration in ppb"
    },
    "co": {
      "type": ["number", "string"],
      "title": "Carbon Monoxide CO",
      "description": "CO concentration in ppm"
    },
    "vIndex": {
      "type": "number",
      "title": "Ventilation Index"
    },
    "tIndex": {
      "type": "number",
      "title": "Thermal Index"
    },
    "virusIndex": {
      "type": "number",
      "title": "Virus Index"
    },
    "iaqIndex": {
      "type": "number",
      "title": "IAQ Index"
    },
    "moldIndex": {
      "type": ["number", "string"],
      "title": "Mold Index"
    },
    "dB": {
      "type": ["number", "string"],
      "title": "Noise Level dB"
    },
    "counter": {
      "type": "number",
      "title": "Message Counter"
    },
    "type": {
      "type": "string",
      "title": "Device Type"
    }
  },
  "required": [
    "temperature",
    "humidity",
    "co2",
    "tvoc",
    "pm2_5",
    "pm10",
    "ch2o",
    "pm1_0",
    "pm4",
    "o3",
    "no2",
    "co"
  ]
}
