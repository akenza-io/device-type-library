{
  "$id": "https://akenza.io/inbiot/well/default.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "processingType": "uplink_decoder",
  "topic": "default",
  "title": "Default",
  "properties": {
    "temperature": {
      "$ref": "https://raw.githubusercontent.com/akenza-io/device-type-library/main/data-models/environment/schema.json#/$defs/temperature/celsius"
    },
    "humidity": {
      "$ref": "https://raw.githubusercontent.com/akenza-io/device-type-library/main/data-models/environment/schema.json#/$defs/humidity/percent"
    },
    "co2": {
      "$ref": "https://raw.githubusercontent.com/akenza-io/device-type-library/main/data-models/environment/schema.json#/$defs/co2/ppm"
    },
    "tvoc": {
      "$ref": "https://raw.githubusercontent.com/akenza-io/device-type-library/main/data-models/environment/schema.json#/$defs/tvoc/ppb"
    },
    "pm2_5": {
      "$ref": "https://raw.githubusercontent.com/akenza-io/device-type-library/main/data-models/environment/schema.json#/$defs/pm2_5/mcgm3"
    },
    "pm10": {
      "$ref": "https://raw.githubusercontent.com/akenza-io/device-type-library/main/data-models/environment/schema.json#/$defs/pm10/mcgm3"
    },
    "ch2o": {
      "type": "number",
      "title": "Formaldehyde CH2O",
      "description": "Formaldehyde concentration in ppb"
    },
    "ch2oStatus": {
      "type": "string",
      "title": "Formaldehyde CH2O Status",
      "description": "Status text for formaldehyde (e.g. Preheating)"
    },
    "pm1": {
      "$ref": "https://raw.githubusercontent.com/akenza-io/device-type-library/main/data-models/environment/schema.json#/$defs/pm1/mcgm3"
    },
    "pm4": {
      "$ref": "https://raw.githubusercontent.com/akenza-io/device-type-library/main/data-models/environment/schema.json#/$defs/pm4/mcgm3"
    },
    "o3": {
      "type": "number",
      "title": "Ozone O3",
      "description": "Ozone concentration in ppb"
    },
    "o3Status": {
      "type": "string",
      "title": "Ozone O3 Status",
      "description": "Status text for ozone (e.g. Preheating)"
    },
    "no2": {
      "type": "number",
      "title": "Nitrogen Dioxide NO2",
      "description": "NO2 concentration in ppb"
    },
    "no2Status": {
      "type": "string",
      "title": "Nitrogen Dioxide NO2 Status",
      "description": "Status text for NO2 (e.g. Preheating)"
    },
    "co": {
      "type": "number",
      "title": "Carbon Monoxide CO",
      "description": "CO concentration in ppm"
    },
    "coStatus": {
      "type": "string",
      "title": "Carbon Monoxide CO Status",
      "description": "Status text for CO (e.g. Preheating)"
    },
    "vIndex": {
      "type": "number",
      "title": "Ventilation Index",
      "description": "Calculated ventilation index"
    },
    "tIndex": {
      "type": "number",
      "title": "Thermal Index",
      "description": "Calculated thermal comfort index"
    },
    "virusIndex": {
      "type": "number",
      "title": "Virus Index",
      "description": "Calculated virus survival index"
    },
    "iaqIndex": {
      "type": "number",
      "title": "IAQ Index",
      "description": "Overall Indoor Air Quality Index"
    },
    "moldIndex": {
      "type": "number",
      "title": "Mold Index",
      "description": "Calculated mold growth risk index"
    },
    "moldIndexStatus": {
      "type": "string",
      "title": "Mold Index Status",
      "description": "Status text for mold index (e.g. Calculating)"
    },
    "noise": {
      "$ref": "https://raw.githubusercontent.com/akenza-io/device-type-library/main/data-models/environment/schema.json#/$defs/soundLevel/dbspl"
    },
    "noiseStatus": {
      "type": "string",
      "title": "Noise Level dB Status",
      "description": "Status text for noise level (e.g. Preheating)"
    },
    "counter": {
      "type": "number",
      "title": "Message Counter",
      "description": "Incrementing message counter value"
    },
    "type": {
      "type": "string",
      "title": "Device Type",
      "description": "Device model identifier"
    }
  },
  "required": [
    "temperature",
    "humidity",
    "co2",
    "tvoc",
    "pm2_5",
    "pm10",
    "pm1",
    "pm4"
  ]
}