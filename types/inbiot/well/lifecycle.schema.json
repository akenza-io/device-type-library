{
  "$id": "https://akenza.io/inbiot/well/lifecycle.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "processingType": "uplink_decoder",
  "topic": "lifecycle",
  "title": "Lifecycle",
  "properties": {
    "fwVersion": {
      "type": "string",
      "title": "Firmware Version",
      "description": "Device firmware version",
