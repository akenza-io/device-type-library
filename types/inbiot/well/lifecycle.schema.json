    },
    "model": {
      "type": "string",
      "title": "Device Model",
      "description": "Model identification string",
      "hideFromKpis": true
    },
    "micaType": {
      "type": "string",
      "title": "MICA Type",
      "description": "Internal model type nomenclature",
      "hideFromKpis": true
    },
    "mac": {
      "type": "string",
      "title": "MAC Address",
      "description": "Device MAC address",
