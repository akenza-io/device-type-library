{
  "$id": "https://akenza.io/inbiot/mini/configuration.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "processingType": "uplink_decoder",
  "topic": "configuration",
  "title": "Configuration",
  "properties": {
    "timeToSend": {
      "type": "number",
      "title": "Time between metrics in minutes"
    },
    "ventilation": {
      "type": "number",
      "title": "Ventilation Type"
    },
    "ledStatus": {
      "type": "boolean",
      "title": "LED Status"
    },
    "useWifi": {
      "type": "boolean",
      "title": "Use Wifi Instead"
    },
    "lorawanRegion": {
      "type": "string",
      "title": "LoRaWAN Region"
    },
    "lorawanChannelMask": {
      "type": "number",
      "title": "LoRaWAN Channel Mask"
    },
    "ledConfiguration": {
      "type": "number",
      "title": "LED Configuration"
    },
    "touchEnable": {
      "type": "boolean",
      "title": "Touch Enable"
    }
  },
  "required": [
    "timeToSend",
    "ledStatus",
    "lorawanRegion"
  ]
}
