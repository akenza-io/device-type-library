{
  "$id": "https://akenza.io/inbiot/mini/lifecycle.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "processingType": "uplink_decoder",
  "topic": "lifecycle",
  "title": "Lifecycle",
  "properties": {
    "fwVersion": {
      "type": "string",
      "title": "Firmware Version",
      "description": "Device firmware version"
    },
    "model": {
      "type": "string",
      "title": "Device Model",
      "description": "Model identification string"
    },
    "micaType": {
      "type": "string",
      "title": "MICA Type",
      "description": "Internal model type nomenclature"
    },
    "mac": {
      "type": "string",
      "title": "MAC Address",
      "description": "Device MAC address"
    },
    "resetReason": {
      "type": "string",
      "title": "Reset Reason",
      "description": "Cause of the last module reset"
    },
    "modbusAddress": {
      "type": "number",
      "title": "Modbus Address",
      "description": "Current Modbus bus address"
    },
    "modbusParity": {
      "type": "number",
      "title": "Modbus Parity",
      "description": "Modbus parity configuration"
    },
    "modbusBaudRate": {
      "type": "number",
      "title": "Modbus Baud Rate",
      "description": "Configured baud rate for Modbus"
    }
  },
  "required": [
    "fwVersion",
    "mac",
    "resetReason"
  ]
}
