{
  "$id": "https://akenza.io/inbiot/plus/downlink.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "processingType": "downlink_encoder",
  "topic": "downlink",
  "title": "Downlink Configuration",
  "properties": {
    "ledStatus": {
      "type": "boolean",
      "title": "LED Status Enable/Disable",
      "description": "Toggle LED functionality"
    },
    "timeToSend": {
      "type": "number",
      "title": "Time To Send (Periodicity in minutes)",
      "description": "Configure transmission periodicity",
      "minimum": 5,
      "maximum": 60,
      "unit": "min"
    },
    "ventilation": {
      "type": "number",
      "title": "CO2 Calibration (Ventilation)",
      "description": "Change CO2 automatic calibration baseline",
      "minimum": 1,
      "maximum": 5
    },
    "ledConfiguration": {
      "type": "number",
      "title": "LED Configuration Indicator",
      "description": "Set specific behavior for LED feedback",
      "minimum": 0,
      "maximum": 16
    },
    "touchEnable": {
      "type": "boolean",
      "title": "Touch Enable",
      "description": "Enable or disable touch button control"
    },
    "ADREnable": {
      "type": "boolean",
      "title": "ADR Enable",
      "description": "Adaptive Data Rate toggle"
    },
    "DR": {
      "type": "number",
      "title": "Data Rate (0-7)",
      "description": "Set base Data Rate",
      "minimum": 0,
      "maximum": 7,
      "unit": "SF"
    },
    "sendRetransmissions": {
      "type": "number",
      "title": "Send Retransmissions (0-15)",
      "description": "Configure number of retransmissions",
      "minimum": 0,
      "maximum": 15
    },
    "TXPower": {
      "type": "number",
      "title": "TX Power (0-15)",
      "description": "Configure transmission power index",
      "minimum": 0,
      "maximum": 15,
      "unit": "dBm"
    },
    "confirmationEnable": {
      "type": "boolean",
      "title": "Confirmation Enable",
      "description": "Require confirmed uplinks"
    },
    "resetDevice": {
      "type": "boolean",
      "title": "Reset Device",
      "description": "Trigger remote reboot"
    }
  }
}