{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/akenza-io/device-type-library/main/data-models/flow/schema.json",
  "title": "Flow",
  "description": "Flow measurements",
  "type": "object",
  "$defs": {
    "flow": {
      "m3h": {
        "measurementType": "akenza/flow/flow/m3h",
        "title": "Flow",
        "description": "Liquid flow in m3/h",
        "type": "number",
        "unit": "m3/h"
      },
      "m3": {
        "measurementType": "akenza/flow/flow/m3",
        "title": "Flow",
        "description": "Liquid flow in m3",
        "type": "number",
        "unit": "m3",
        "counterType": "monotonic"
      },
      "m3Delta": {
        "measurementType": "akenza/flow/flow/m3Delta",
        "title": "Flow",
        "description": "Liquid flow in m3 since last transmission in",
        "type": "number",
        "unit": "m3",
        "counterType": "delta"
      }
    },
    "consumption": {
      "l": {
        "measurementType": "akenza/flow/consumption/l",
        "title": "Consumption",
        "description": "Liquid consumption in liters",
        "type": "number",
        "unit": "l",
        "counterType": "monotonic"
      },
      "lDelta": {
        "measurementType": "akenza/flow/consumption/lDelta",
        "title": "Consumption Delta",
        "description": "Liquid consumption since last transmission in liters",
        "type": "number",
        "unit": "l",
        "counterType": "delta"
      }
    },
    "volume": {
      "l": {
        "measurementType": "akenza/flow/volume/l",
        "title": "Volume",
        "description": "Liquid volume in liters",
        "type": "number",
        "unit": "l",
        "counterType": "monotonic"
      },
      "m3": {
        "measurementType": "akenza/flow/volume/m3",
        "title": "Volume",
        "description": "Liquid volume in cubic meter",
        "type": "number",
        "unit": "m3",
        "counterType": "monotonic"
      },
      "lDelta": {
        "measurementType": "akenza/flow/volume/lDelta",
        "title": "Volume Delta",
        "description": "Liquid volume since last transmission in liters",
        "type": "number",
        "unit": "l",
        "counterType": "delta"
      },
      "m3Delta": {
        "measurementType": "akenza/flow/volume/m3Delta",
        "title": "Volume Delta",
        "description": "Liquid volume since last transmission in cubic meters",
        "type": "number",
        "unit": "m3",
        "counterType": "delta"
      }
    }
  }
}